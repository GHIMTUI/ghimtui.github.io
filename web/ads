<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>Adblock Editor - Smart Sorting & Counting</title>
    <style>
        * {
            box-sizing: border-box; 
            -webkit-tap-highlight-color: transparent;
        }
        html, body {
    height: 100svh; /* Đơn vị mới giúp khớp chuẩn màn hình di động */
    margin: 0;
    padding: 0;
    overflow: hidden;
    font-family: 'Segoe UI', system-ui, sans-serif;
    background-color: #1e1e1e;
    /* Chặn việc kéo trang gây mất layout */
    position: fixed; 
    width: 100%;
}


        .editor-container {
            display: flex;
            flex-direction: column;
            height: 100%;
            width: 100%;
        }

        .toolbar {
            background-color: #2d2d2d;
            color: #ccc;
            padding: 0 15px;
            height: 60px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid #3c3c3c;
            box-sizing: border-box;
        }

        .info-path {
            font-family: monospace;
            font-size: 13px;
            color: #9cdcfe;
            font-weight: bold;
        }

        button {
            background-color: #28a745;
            color: white;
            border: none;
            padding: 10px 20px;
            font-size: 13px;
            font-weight: bold;
            border-radius: 4px;
            cursor: pointer;
            transition: all 0.2s;
        }

        button:disabled {
            background-color: #444;
            opacity: 0.5;
            cursor: not-allowed;
        }

        .textarea-wrapper {
            flex: 1;
            background-color: #1e1e1e;
        }

        textarea {
            width: 100%;
            height: 100%;
            border: none;
            padding: 15px;
            background-color: #1e1e1e;
            color: #d4d4d4;
            font-family: 'Consolas', monospace;
            font-size: 16px;
            line-height: 1.5;
            outline: none;
            resize: none;
            box-sizing: border-box;
        }
    </style>
</head>
<body>

<div class="editor-container">
    <div class="toolbar">
        <div class="info-path">ADBLOCK EDITOR</div>
        <div class="actions">
            <button id="svBtn" disabled>LƯU DỮ LIỆU</button>
        </div>
    </div>

    <div class="textarea-wrapper">
        <textarea id="txtAr" spellcheck="false" placeholder="Đang tải dữ liệu..."></textarea>
    </div>
</div>

<script>
(function() {
    const _0x_u1 = ["Z2hwX3RLZzVQTFlk", "VlQweElPcko0R3VaSVU4S0M2V3BoTDNoUXhuZw=="];
    const _init_key = () => atob(_0x_u1[0] + _0x_u1[1]);

    const _app_opt = {
        _k: _init_key(),
        _o: "ghimtui",
        _r: "ghimtui.github.io",
        _p: "file/ads.txt"
    };

    const _ep_url = `https://api.github.com/repos/${_app_opt._o}/${_app_opt._r}/contents/${_app_opt._p}`;
    
    const _dom_ar = document.getElementById('txtAr');
    const _dom_sv = document.getElementById('svBtn');

    let _v_sha = null;
    let _last_saved_rules_flat = ""; 

    function _standardize_content(rawInput) {
        let lines = rawInput.split('\n').map(l => l.trim()).filter(l => l !== "");
        
        let bodyLines = [];
        
        // Loại bỏ metadata cũ và tách lấy nội dung chính
        lines.forEach(line => {
            if (line.match(/! (Title|Description|Updated|Version|Blocked|Size|=======)/i) || line.startsWith("[Adblock")) {
                return;
            }
            if (!line.startsWith('!')) {
                bodyLines.push(line);
            }
        });

        // --- LOGIC GỘP LINK GIỐNG NHAU ---
        // Sử dụng Map để gom nhóm: domain -> Set(selectors)
        let mergedMap = new Map();
        let otherRules = []; // Dành cho whitelist @@|| hoặc các quy tắc không chứa ##

        bodyLines.forEach(line => {
            if (line.includes('##') && !line.startsWith('@@')) {
                let [domain, selector] = line.split('##');
                if (!mergedMap.has(domain)) {
                    mergedMap.set(domain, new Set());
                }
                // Tách các selector con nếu dòng cũ đã có dấu phẩy
                selector.split(',').forEach(s => mergedMap.get(domain).add(s.trim()));
            } else {
                otherRules.push(line);
            }
        });

        let processedBody = [];
        // Chuyển Map ngược lại thành mảng dòng text
        mergedMap.forEach((selectors, domain) => {
            processedBody.push(`${domain}##${Array.from(selectors).join(',')}`);
        });
        processedBody = [...processedBody, ...otherRules];

        // Sắp xếp: Whitelist (@@||) luôn ở dưới cùng
        let whitelistRules = Array.from(new Set(processedBody.filter(line => line.startsWith("@@||")))).sort();
        let normalRules = Array.from(new Set(processedBody.filter(line => !line.startsWith("@@||") && line !== ""))).sort();
        
        let uniqueBody = [...normalRules, ...whitelistRules];
        
        // Đếm dòng thực tế (chỉ đếm dòng bắt đầu bằng chữ/số)
        let realRuleCount = uniqueBody.filter(line => /^[a-zA-Z0-9]/.test(line)).length;
        
        let currentRulesFlat = uniqueBody.join('\n');
        let isChanged = currentRulesFlat !== _last_saved_rules_flat;

        // Xử lý Version
        let version = "1.0.0";
        const v_match = rawInput.match(/!\s*Version:\s*(\d+)\.(\d+)\.(\d+)/i);
        if (v_match) {
            let v_major = v_match[1];
            let v_minor = v_match[2];
            let v_patch = parseInt(v_match[3]);
            if (isChanged) v_patch += 1;
            version = `${v_major}.${v_minor}.${v_patch}`;
        }

        const now = new Date();
        const time_str = now.toLocaleString('en-GB', { 
            day: '2-digit', month: 'short', year: 'numeric', 
            hour: '2-digit', minute: '2-digit', hour12: false 
        }).replace(',', '');

        // Xây dựng nội dung hiển thị có khoảng cách nhóm
        let tempBodyOutput = [];
        let lastChar = "";
        uniqueBody.forEach(line => {
            if (line.startsWith("@@||")) {
                if (lastChar !== "WL_GROUP") {
                    tempBodyOutput.push(""); 
                    lastChar = "WL_GROUP";
                }
            } else {
                let currentChar = line[0].toLowerCase();
                if (!/[a-z0-9]/.test(currentChar)) currentChar = "SPEC";
                if (lastChar && lastChar !== "WL_GROUP" && currentChar !== lastChar) {
                    tempBodyOutput.push(""); 
                }
                lastChar = currentChar;
            }
            tempBodyOutput.push(line);
        });

        const headerPrefix = [
            "[Adblock Plus 2.0]",
            "! Title: STOP ADS",
            "! Describe: Chặn quảng cáo",
            `! Updated: ${time_str}`,
            `! Version: ${version}`,
            `! Blocked: ${realRuleCount}`
        ];
        
        const mockContent = [...headerPrefix, "! Size: 00.0kb", "! ==================", "", ...tempBodyOutput].join('\n');
        const kbSize = (new TextEncoder().encode(mockContent).length / 1024).toFixed(2);

        let finalOutput = [
            ...headerPrefix,
            `! Size: ${kbSize}kb`,
            "! ==================",
            "",
            ...tempBodyOutput
        ];

        return {
            content: finalOutput.join('\n'),
            version: version,
            count: realRuleCount,
            isChanged: isChanged,
            rulesFlat: currentRulesFlat
        };
    }

    async function _load() {
        try {
            const res = await fetch(_ep_url, {
                headers: { "Authorization": `Bearer ${_app_opt._k}` }
            });
            if (res.ok) {
                const data = await res.json();
                _v_sha = data.sha;
                const raw = atob(data.content);
                const dec = decodeURIComponent(raw.split('').map(c => '%' + ('00' + c.charCodeAt(0).toString(16)).slice(-2)).join(''));
                
                _dom_ar.value = dec;
                
                let lines = dec.split('\n').map(l => l.trim()).filter(l => l && !l.startsWith('!') && !l.startsWith('['));
                let wl = lines.filter(l => l.startsWith("@@||")).sort();
                let nl = lines.filter(l => !l.startsWith("@@||")).sort();
                _last_saved_rules_flat = [...nl, ...wl].join('\n');
            }
            _dom_sv.disabled = false;
        } catch (e) { console.error("Load error"); }
    }

    _dom_sv.addEventListener('click', async () => {
        const result = _standardize_content(_dom_ar.value);
        _dom_ar.value = result.content;

        _dom_sv.disabled = true;
        try {
            const enc = new TextEncoder().encode(result.content);
            const b64 = btoa(String.fromCharCode(...enc));
            
            const res = await fetch(_ep_url, {
                method: "PUT",
                headers: {
                    "Authorization": `Bearer ${_app_opt._k}`,
                    "Content-Type": "application/json"
                },
                body: JSON.stringify({
                    message: `v${result.version} (${result.count} rules)`,
                    content: b64,
                    sha: _v_sha
                })
            });

            if (res.ok) {
                const d = await res.json();
                _v_sha = d.content.sha;
                _last_saved_rules_flat = result.rulesFlat;
                console.log("Saved success: v" + result.version);
            }
        } catch (e) { console.error("Save error"); }
        _dom_sv.disabled = false;
    });

    window.onload = _load;
})();

</script>

</body>
</html>
